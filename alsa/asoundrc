pcm.!default
{
    type plug
    slave.pcm "asym"
}
pcm.asym
{
        type asym
        capture.pcm {
                type plug
                slave.pcm "usb_mic"
        }
        playback.pcm {
                type plug
                slave.pcm "softvol"
        }
        hint {
            show on
            name "test2"
            description "USB mic and monitor."
        }
}
pcm.usb_mic
{
    type hw
    card "Mini"
}
pcm.softvol
{
    type softvol
    slave.pcm "dmixer"
    control
    {
        name "myPCM"
        card 0
    }
}
pcm.dmixer 
{
    type dmix
    ipc_key 1024
    slave {
        pcm "monitor"
        channels 2
        rate 48000
        format unchanged
        #period_size 1024
        #buffer_size 8192
    }
}
pcm.monitor
{
    type hw
    card "HDMI"
    device 7
}
